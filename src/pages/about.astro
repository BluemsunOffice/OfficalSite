---
import PageComposer from "../components/composition/PageComposer.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { getPageComposition } from "../lib/page-composition";

const composition = await getPageComposition("about");
---

<MainLayout title={composition.title} description={composition.description}>
  <PageComposer composition={composition} />
</MainLayout>
