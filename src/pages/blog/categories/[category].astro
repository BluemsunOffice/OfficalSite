---
import { getCollection } from "astro:content";
import ContentIndexSection from "../../../components/content/ContentIndexSection.astro";
import MainLayout from "../../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection(
    "blog",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );
  const categories = [
    ...new Set(entries.flatMap((entry) => entry.data.categories)),
  ];

  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      entries: entries
        .filter((entry) => entry.data.categories.includes(category))
        .sort(
          (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
        ),
    },
  }));
}

const { category, entries } = Astro.props;
---

<MainLayout title={`分类: ${category}`} description={`博客分类 ${category}`}>
  <ContentIndexSection
    title={`分类：${category}`}
    description="该分类下的文章按时间倒序展示。"
    eyebrow="BLOG CATEGORY"
    entries={entries}
    emptyText="该分类下暂无内容。"
    hrefPrefix="/blog/"
  />
</MainLayout>
