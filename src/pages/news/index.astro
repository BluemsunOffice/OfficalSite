---
import ContentIndexSection from "../../components/content/ContentIndexSection.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getPublishedCollection } from "../../lib/collections";

const entries = await getPublishedCollection("news");
---

<MainLayout title="新闻" description="蓝旭工作室新闻动态">
  <ContentIndexSection
    title="新闻"
    description="活动、竞赛与成果的最新动态。"
    eyebrow="NEWS"
    entries={entries}
    emptyText="暂无新闻内容。"
    hrefPrefix="/news/"
  />
</MainLayout>
