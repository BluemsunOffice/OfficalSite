---
interface Props {
  name?: string;
  id?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  rows?: number;
  class?: string;
}

const {
  name,
  id,
  placeholder,
  value,
  required = false,
  disabled = false,
  rows = 4,
  class: customClass = "",
} = Astro.props;

const textareaClass =
  "bg-transparent outline-none w-full text-sm placeholder-ink-400 resize-none";
const combinedTextareaClass = `${textareaClass} ${customClass}`.trim();
---

<div
  class="textarea-wrapper rounded-lg border border-blue-300 bg-white shadow-sm transition p-3"
>
  <div class="flex items-start gap-2 mb-2">
    <slot name="prefix" />
  </div>
  <textarea
    {name}
    {id}
    {placeholder}
    {required}
    {disabled}
    {rows}
    class={combinedTextareaClass}>{value}</textarea
  >
  <div class="flex items-end gap-2 mt-2">
    <slot name="suffix" />
  </div>
</div>

<style>
  .textarea-wrapper {
    border-color: rgb(191, 219, 254);
    background-color: rgb(255, 255, 255);
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .textarea-wrapper:focus-within {
    border-color: rgb(96, 165, 250);
    box-shadow: 0 0 0 2px rgba(219, 234, 255, 1);
  }
</style>
