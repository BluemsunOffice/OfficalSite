---
interface Props {
  name?: string;
  id?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  rows?: number;
  class?: string;
}

const {
  name,
  id,
  placeholder,
  value,
  required = false,
  disabled = false,
  rows = 4,
  class: customClass = "",
} = Astro.props;

const baseClass =
  "rounded-lg border border-blue-300 bg-white px-3 py-2.5 text-sm outline-none transition placeholder-ink-400 focus:border-blue-400 focus:ring-2 focus:ring-brand-200 shadow-sm resize-none";
const combinedClass = `${baseClass} ${customClass}`.trim();
---

<textarea
  {name}
  {id}
  {placeholder}
  {required}
  {disabled}
  {rows}
  class={combinedClass}>{value}</textarea
>
