---
import {
  ArrowRight,
  ArrowUpRight,
  CircleUserRound,
  FileText,
  FlaskConical,
  Home,
  Newspaper,
  UserPlus,
  type LucideIcon,
} from "lucide-react";

type LinkIconName =
  | "home"
  | "blog"
  | "news"
  | "project"
  | "about"
  | "join"
  | "arrow-right"
  | "external";

type LinkSizePreset = "small" | "default" | "large";

type LinkSize = LinkSizePreset | `${number}px`;

interface Props {
  href: string;
  class?: string;
  target?: string;
  rel?: string;
  variant?: "default" | "primary" | "secondary" | "outline" | "rainbowOutline";
  icon?: LinkIconName;
  iconPosition?: "start" | "end";
  iconSize?: number;
  iconClass?: string;
  size?: LinkSize;
}

const iconMap: Record<LinkIconName, LucideIcon> = {
  home: Home,
  blog: FileText,
  news: Newspaper,
  project: FlaskConical,
  about: CircleUserRound,
  join: UserPlus,
  "arrow-right": ArrowRight,
  external: ArrowUpRight,
};

const {
  href,
  class: customClass = "",
  target,
  rel,
  variant = "default",
  icon,
  iconPosition = "start",
  iconSize,
  iconClass = "shrink-0",
  size = "default",
} = Astro.props;

const Icon = icon ? iconMap[icon] : null;

const sizeClassByPreset: Record<LinkSizePreset, string> = {
  small: "px-2 py-1 text-xs",
  default: "px-2.5 py-2 text-sm",
  large: "px-4 py-2 text-base",
};

const presetIconSize: Record<LinkSizePreset, number> = {
  small: 14,
  default: 16,
  large: 18,
};

const isPresetSize = size === "small" || size === "default" || size === "large";
const normalizedPreset = isPresetSize ? size : "default";
const hasCustomSize = !isPresetSize;

const sizeClass = hasCustomSize ? "" : sizeClassByPreset[normalizedPreset];
const customSizeStyle = hasCustomSize
  ? `font-size: clamp(12px, calc(${size} * 0.24), 24px); padding: clamp(6px, calc(${size} * 0.2), 22px) clamp(10px, calc(${size} * 0.36), 36px);`
  : undefined;

const computedIconSize =
  iconSize ??
  (variant === "rainbowOutline"
    ? presetIconSize[normalizedPreset] + 1
    : presetIconSize[normalizedPreset]);

const variantClass = {
  default: "text-inherit hover:underline",
  primary:
    "inline-flex rounded-lg bg-brand-500 font-semibold text-white transition hover:bg-brand-700",
  secondary:
    "inline-flex rounded-lg border border-brand-200 bg-white font-semibold text-ink-700 transition hover:border-brand-400 hover:text-brand-500",
  outline:
    "inline-flex rounded-lg border border-brand-200 bg-white font-semibold text-ink-700 transition hover:border-brand-300 hover:text-brand-500",
  rainbowOutline:
    "inline-flex rounded-xl border border-transparent font-semibold text-cyan-700 transition-all duration-300 [background:linear-gradient(#fff,#fff)_padding-box,linear-gradient(120deg,#22d3ee,#34d399,#f59e0b,#f472b6,#60a5fa)_border-box] hover:text-fuchsia-700 hover:shadow-[0_10px_24px_rgb(15_23_42/14%)] hover:[background:linear-gradient(#fff,#fff)_padding-box,linear-gradient(120deg,#38bdf8,#2dd4bf,#fbbf24,#fb7185,#818cf8)_border-box]",
}[variant];

const baseClass = variant === "default" ? "transition" : "";
const iconLayoutClass = icon ? "inline-flex items-center gap-2" : "";
const combinedClass =
  `${baseClass} ${variantClass} ${sizeClass} ${iconLayoutClass} ${customClass}`.trim();
---

<a {href} {target} {rel} class={combinedClass} style={customSizeStyle}>
  {
    Icon && iconPosition === "start" && (
      <Icon size={computedIconSize} className={iconClass} aria-hidden="true" />
    )
  }
  <slot />
  {
    Icon && iconPosition === "end" && (
      <Icon size={computedIconSize} className={iconClass} aria-hidden="true" />
    )
  }
</a>
