---
interface Props {
  href: string;
  class?: string;
  target?: string;
  rel?: string;
  variant?: "default" | "primary" | "secondary" | "outline";
}

const {
  href,
  class: customClass = "",
  target,
  rel,
  variant = "default",
} = Astro.props;

const variantClass = {
  default: "text-inherit hover:underline",
  primary:
    "inline-flex rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700",
  secondary:
    "inline-flex rounded-lg border border-brand-200 bg-white px-4 py-2.5 text-sm font-semibold text-ink-700 transition hover:border-brand-400 hover:text-brand-500",
  outline:
    "inline-flex rounded-lg border border-brand-200 bg-white px-3 py-2 text-xs font-semibold text-ink-700 transition hover:border-brand-300 hover:text-brand-500",
}[variant];

const baseClass = variant === "default" ? "transition" : "";
const combinedClass = `${baseClass} ${variantClass} ${customClass}`.trim();
---

<a {href} {target} {rel} class={combinedClass}>
  <slot />
</a>
