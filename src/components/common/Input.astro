---
type InputType =
  | "text"
  | "email"
  | "password"
  | "number"
  | "tel"
  | "url"
  | "search"
  | "date"
  | "time"
  | "datetime-local"
  | "month"
  | "week"
  | "color"
  | "file"
  | "hidden";

interface Props {
  name?: string;
  placeholder?: string;
  type?: InputType;
  value?: string;
  required?: boolean;
  disabled?: boolean;
  id?: string;
  class?: string;
}

const {
  name,
  placeholder,
  type = "text",
  value,
  required = false,
  disabled = false,
  id,
  class: customClass = "",
} = Astro.props;

const inputClass =
  "bg-transparent outline-none placeholder-ink-400 flex-1 text-sm";
const combinedInputClass = `${inputClass} ${customClass}`.trim();
---

<div
  class="input-wrapper inline-flex items-center gap-2 rounded-lg border border-blue-300 bg-white px-3 py-2.5 shadow-sm transition"
>
  <slot name="prefix" />
  <input
    {type}
    {name}
    {placeholder}
    {value}
    {id}
    {required}
    {disabled}
    class={combinedInputClass}
  />
  <slot name="suffix" />
</div>

<style>
  .input-wrapper {
    border-color: rgb(191, 219, 254);
    background-color: rgb(255, 255, 255);
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  .input-wrapper:focus-within {
    border-color: rgb(96, 165, 250);
    box-shadow: 0 0 0 2px rgba(219, 234, 255, 1);
  }
</style>
