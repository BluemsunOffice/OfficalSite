---
interface Props {
  id?: string;
  name?: string;
  accept?: string;
  required?: boolean;
  disabled?: boolean;
  multiple?: boolean;
  label?: string;
  class?: string;
}

const {
  id,
  name,
  accept = "image/png, image/jpeg, image/gif, image/webp, image/svg+xml",
  required = false,
  disabled = false,
  multiple = false,
  label = "选择文件",
  class: customClass = "",
} = Astro.props;

const baseClass =
  "inline-flex items-center gap-2 cursor-pointer rounded-lg border border-blue-300 bg-white px-3 py-2.5 text-sm transition hover:border-blue-400 shadow-sm";
const combinedClass = `${baseClass} ${customClass}`.trim();
---

<label for={id} class={combinedClass}>
  <slot name="icon" />
  <span>{label}</span>
  <input
    {id}
    {name}
    {accept}
    {required}
    {disabled}
    {multiple}
    type="file"
    class="hidden"
  />
</label>
