---
interface Props {
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  id?: string;
  class?: string;
  variant?: "primary" | "secondary" | "outline";
}

const {
  type = "button",
  disabled = false,
  id,
  class: customClass = "",
  variant = "primary",
} = Astro.props;

const variantClass = {
  primary: "bg-brand-500 text-white hover:bg-brand-700",
  secondary: "bg-ink-200 text-ink-900 hover:bg-ink-300",
  outline: "border border-brand-500 text-brand-500 hover:bg-brand-50",
}[variant];

const baseClass =
  "rounded-lg px-4 py-2.5 text-sm font-semibold transition cursor-pointer";
const combinedClass = `${baseClass} ${variantClass} ${customClass}`.trim();
---

<button {type} {disabled} {id} class={combinedClass} disabled={disabled}>
  <slot />
</button>
