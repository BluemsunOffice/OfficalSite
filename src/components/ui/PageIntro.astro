---
type IntroTag = {
  label: string;
  href?: string;
};

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  tags?: IntroTag[];
}

const { title, description, eyebrow, tags = [] } = Astro.props;
const visibleTags = tags.slice(0, 10);
const hiddenTagCount = Math.max(tags.length - visibleTags.length, 0);
---

<header class="mb-6 rounded-2xl border border-brand-100/80 bg-white/80 p-5 shadow-[0_8px_24px_rgb(10_102_245/8%)] backdrop-blur-sm">
  {eyebrow && <p class="mono mb-2 text-xs font-semibold tracking-wide text-brand-500">{eyebrow}</p>}
  <h1 class="text-[clamp(1.4rem,2.2vw,2.1rem)] font-bold text-ink-900">{title}</h1>
  {description && <p class="mt-2 max-w-3xl text-sm leading-7 text-ink-500">{description}</p>}
  {
    visibleTags.length > 0 && (
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="text-xs font-medium text-ink-500">标签</span>
        {visibleTags.map((tag) =>
          tag.href ? (
            <a
              href={tag.href}
              class="mono rounded-full border border-brand-200 bg-brand-50 px-2.5 py-1 text-xs text-brand-600 transition hover:border-brand-300"
            >
              {tag.label}
            </a>
          ) : (
            <span class="mono rounded-full border border-brand-200 bg-brand-50 px-2.5 py-1 text-xs text-brand-600">
              {tag.label}
            </span>
          ),
        )}
        {
          hiddenTagCount > 0 && (
            <span class="text-xs text-ink-400">+{hiddenTagCount}</span>
          )
        }
      </div>
    )
  }
</header>
