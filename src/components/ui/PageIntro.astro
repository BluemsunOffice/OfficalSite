---
interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="mb-6 rounded-2xl border border-brand-100/80 bg-white/80 p-5 shadow-[0_8px_24px_rgb(10_102_245/8%)] backdrop-blur-sm">
  {eyebrow && <p class="mono mb-2 text-xs font-semibold tracking-wide text-brand-500">{eyebrow}</p>}
  <h1 class="text-[clamp(1.4rem,2.2vw,2.1rem)] font-bold text-ink-900">{title}</h1>
  {description && <p class="mt-2 max-w-3xl text-sm leading-7 text-ink-500">{description}</p>}
</header>
