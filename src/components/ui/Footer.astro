---
import { siteConfig } from "../../config/site";
---

<footer class="mt-12 border-t border-brand-100 bg-surface">
  <div class="container-shell grid gap-6 py-10">
    <div class="grid gap-4 md:grid-cols-[1.2fr_1fr_1fr]">
      <div>
        <p class="m-0 text-base font-semibold text-ink-900">{siteConfig.zhName}</p>
        <p class="mono mt-1 text-xs text-brand-500">{siteConfig.slogan}</p>
        <p class="mt-3 max-w-sm text-sm leading-7 text-ink-500">{siteConfig.description}</p>
      </div>
      <div>
        <p class="mono text-xs text-ink-500">NAVIGATION</p>
        <div class="mt-2 grid gap-2">
          {
            siteConfig.nav.slice(0, 4).map((item) => (
              <a href={item.href} class="text-sm text-ink-700 transition hover:text-brand-500">
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <p class="mono text-xs text-ink-500">CONNECT</p>
        <div class="mt-2 flex flex-wrap gap-2">
          {
            siteConfig.socials.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noreferrer"
                class="rounded-lg border border-brand-100 bg-white px-3 py-1.5 text-sm font-medium text-ink-700 transition hover:border-brand-300 hover:text-brand-500"
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-2 border-t border-brand-100/80 pt-4">
      <p class="m-0 text-sm text-ink-500">
        {siteConfig.footer.copyright}
        {new Date().getFullYear()}
      </p>
      <p class="m-0 text-sm text-ink-500">{siteConfig.footer.beian}</p>
    </div>
  </div>
</footer>
