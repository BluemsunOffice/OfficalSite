---
import { siteConfig } from "../../config/site";
import MotionNavPill from "../motion/MotionNavPill";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header
  id="site-header"
  data-show="true"
  class="sticky top-0 z-30 border-b border-transparent bg-bg/82 backdrop-blur-md transition-all duration-300 will-change-transform"
>
  <div class="container-shell py-3">
    <div class="grid items-center gap-3 md:grid-cols-[1fr_auto_1fr]">
      <a href="/" class="flex items-center gap-2.5">
        <span class="grid h-10 w-10 place-items-center rounded-xl border border-brand-200 bg-white shadow-[0_6px_16px_rgb(10_102_245/10%)]">
          <img
            src="/studio-logo.png"
            alt="蓝旭工作室 Logo"
            class="h-8 w-8 object-contain"
            loading="eager"
            decoding="async"
          />
        </span>
        <span class="min-w-0">
          <strong class="block truncate text-sm font-extrabold tracking-[0.2px] text-ink-900 md:text-base">
            {siteConfig.zhName}
          </strong>
          <span class="mono block truncate text-[11px] text-ink-500 md:text-xs">
            {siteConfig.slogan}
          </span>
        </span>
      </a>

      <div class="hidden md:block">
        <MotionNavPill client:idle items={siteConfig.nav} currentPath={currentPath} />
      </div>

      <div class="hidden items-center justify-end gap-2 md:flex">
        <a
          href={siteConfig.socials[0]?.href}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg border border-brand-100 bg-white px-3 py-2 text-xs font-semibold text-ink-700 transition hover:border-brand-300 hover:text-brand-500"
        >
          GitHub
        </a>
        <a
          href="/join/"
          class="rounded-lg bg-brand-500 px-3.5 py-2 text-xs font-semibold text-white transition hover:bg-brand-700"
        >
          联系我们
        </a>
      </div>
    </div>

    <div class="mt-3 md:hidden">
      <button
        id="mobile-nav-toggle"
        type="button"
        class="inline-flex items-center gap-2 rounded-lg border border-brand-100 bg-white px-3 py-2 text-sm font-semibold text-ink-700"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <span class="mono text-brand-500">NAV</span>
        菜单
      </button>
      <div
        id="mobile-nav-panel"
        class="mt-2 grid max-h-0 overflow-hidden opacity-0 transition-all duration-300"
      >
        <MotionNavPill
          client:visible
          items={siteConfig.nav}
          currentPath={currentPath}
          compact
        />
        <div class="mt-2 grid gap-2">
          <a
            href={siteConfig.socials[0]?.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-lg border border-brand-100 bg-white px-3 py-2 text-sm font-medium text-ink-700"
          >
            GitHub
          </a>
          <a href="/join/" class="rounded-lg bg-brand-500 px-3 py-2 text-sm font-semibold text-white">
            联系我们
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav-panel");

  if (toggle && panel) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", expanded ? "false" : "true");
      panel.classList.toggle("max-h-96", !expanded);
      panel.classList.toggle("opacity-100", !expanded);
      panel.classList.toggle("max-h-0", expanded);
      panel.classList.toggle("opacity-0", expanded);
    });
  }

  if (header) {
    let lastY = window.scrollY;
    let ticking = false;
    const delta = 10;
    const topBuffer = 80;

    const updateHeaderVisibility = () => {
      const currentY = window.scrollY;
      const diff = currentY - lastY;
      header.classList.toggle("border-brand-100/80", currentY > 18);
      header.classList.toggle("shadow-[0_8px_20px_rgb(10_102_245/8%)]", currentY > 18);

      if (Math.abs(diff) <= delta) {
        ticking = false;
        return;
      }

      const mobileMenuExpanded =
        toggle && panel
          ? toggle.getAttribute("aria-expanded") === "true" && !panel.classList.contains("hidden")
          : false;

      if (mobileMenuExpanded || currentY <= topBuffer || diff < 0) {
        header.classList.remove("-translate-y-full");
        header.dataset.show = "true";
      } else if (diff > 0) {
        header.classList.add("-translate-y-full");
        header.dataset.show = "false";
      }

      lastY = currentY;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(updateHeaderVisibility);
          ticking = true;
        }
      },
      { passive: true },
    );
  }
</script>
