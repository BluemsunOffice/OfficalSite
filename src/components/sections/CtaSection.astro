---
import SurfaceCard from "../ui/SurfaceCard.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  primaryText: string;
  primaryHref: string;
}

const { id, title, description, primaryText, primaryHref } = Astro.props;
---

<section id={id} class="section-shell">
  <div class="container-shell">
    <SurfaceCard class="border-brand-500 bg-linear-to-r from-white to-brand-50 p-6">
      <h2 class="text-2xl font-bold text-ink-900">{title}</h2>
      {description && <p class="mt-3 text-ink-500">{description}</p>}
      <div class="mt-4">
        <a
          href={primaryHref}
          class="inline-flex rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700"
        >
          {primaryText}
        </a>
      </div>
    </SurfaceCard>
  </div>
</section>
