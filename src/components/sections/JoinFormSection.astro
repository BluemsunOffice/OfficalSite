---
import SurfaceCard from "../ui/SurfaceCard.astro";
import JoinForm from "./components/JoinForm/index";

interface Props {
  id?: string;
  title?: string;
  description?: string;
  endpointEnv: string;
  uploadEndpoint?: string;
  submitEndpoint?: string;
  successMessage?: string;
  failureMessage?: string;
  imageQuality?: number;
  imageMaxWidth?: number;
  imageMaxHeight?: number;
  studentIdLength?: number;
}

const {
  id,
  title = "报名表单",
  description,
  endpointEnv,
  uploadEndpoint = "http://www.bluemsun.com.cn:8000/upload/img",
  submitEndpoint = "http://www.bluemsun.com.cn:8000/upload/application",
  successMessage = "提交成功。",
  failureMessage = "提交失败。",
  imageQuality = 0.9,
  imageMaxWidth = 800,
  imageMaxHeight = 600,
  studentIdLength = 10,
} = Astro.props;

const endpoint = process.env[endpointEnv] ?? submitEndpoint;
---

<section id={id} class="section-shell">
  <div class="container-shell">
    <SurfaceCard class="p-5">
      <h2 class="text-2xl font-bold text-ink-900">{title}</h2>
      {description && <p class="mt-3 text-ink-500">{description}</p>}
      <JoinForm
        client:load
        endpoint={endpoint}
        uploadEndpoint={uploadEndpoint}
        successMessage={successMessage}
        failureMessage={failureMessage}
        imageQuality={imageQuality}
        imageMaxWidth={imageMaxWidth}
        imageMaxHeight={imageMaxHeight}
        studentIdLength={studentIdLength}
      />
    </SurfaceCard>
  </div>
</section>
