---
import type { CollectionEntry } from "astro:content";
import ContentLayoutGrid from "../motion/ContentLayoutGrid";
import PageIntro from "../ui/PageIntro.astro";
import SurfaceCard from "../ui/SurfaceCard.astro";

type AnyEntry = CollectionEntry<"blog" | "news" | "projects">;

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  entries: AnyEntry[];
  emptyText: string;
  hrefPrefix: "/blog/" | "/news/" | "/projects/";
  showIntroTags?: boolean;
}

const {
  title,
  description,
  eyebrow,
  entries,
  emptyText,
  hrefPrefix,
  showIntroTags = true,
} =
  Astro.props;

const storageKeyMap: Record<string, string> = {
  "/blog/": "layout-columns-blog",
  "/news/": "layout-columns-news",
  "/projects/": "layout-columns-projects",
};
const storageKey = storageKeyMap[hrefPrefix] ?? "layout-columns-default";

const items = entries.map((entry) => ({
  id: entry.id,
  href: `${hrefPrefix}${entry.id}/`,
  title: entry.data.title,
  description: entry.data.description,
  dateText: entry.data.date.toLocaleDateString("zh-CN"),
  dateValue: entry.data.date.toISOString(),
  meta: entry.data.author,
  author: entry.data.author,
  tags: entry.data.tags,
}));

const introTags = [...new Set(entries.flatMap((entry) => entry.data.tags))]
  .sort((a, b) => a.localeCompare(b, "zh-CN"))
  .map((tag) => ({
    label: tag,
    href: hrefPrefix === "/blog/" ? `/blog/tags/${encodeURIComponent(tag)}/` : undefined,
  }));
---

<section class="section-shell">
  <div class="container-shell">
    <PageIntro
      title={title}
      description={description}
      eyebrow={eyebrow}
      tags={showIntroTags ? introTags : []}
    />
    {
      entries.length > 0 ? (
        <ContentLayoutGrid
          client:load
          items={items}
          storageKey={storageKey}
          emptyText={emptyText}
        />
      ) : (
        <SurfaceCard class="p-4 text-ink-500">{emptyText}</SurfaceCard>
      )
    }
  </div>
</section>
